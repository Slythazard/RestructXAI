# =========================
# Message Brokers
# =========================

RABBITMQ_SERVER_URL=amqp://guest:guest@rabbitmq:5672/
REDIS_SERVER_URL=redis://redis:6379


# =========================
# RunPod
# =========================

RUNPOD_API_ENDPOINT=https://api.runpod.ai/v2/<endpoint-id>/run
RUNPOD_API_KEY=your_runpod_api_key


# =========================
# MinIO
# =========================

MINIO_SERVER_URL=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=strong_minio_password


# =========================
# Storage
# =========================

BUCKET=your_minio_bucket_name
